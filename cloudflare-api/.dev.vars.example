# Copy this file to cloudflare-api/.dev.vars for local wrangler dev usage.
# Do not commit cloudflare-api/.dev.vars with real values.

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# Worker behavior
CORS_ORIGINS=http://localhost:5173,https://price-tracker-app.pages.dev
DEFAULT_REFRESH_MINUTES=360
MIN_REFRESH_MINUTES=15
MAX_CRON_REFRESHES_PER_RUN=12
ALLOW_SYNTHETIC=0
