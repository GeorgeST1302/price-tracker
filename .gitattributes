# Normalize line endings for cross-platform consistency.
* text=auto

# Keep source files LF to avoid CRLF churn in CI/Linux deploys.
*.py  text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
