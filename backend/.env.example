# Copy this file to backend/.env for local development.
# Do not commit backend/.env with real values.

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_CONNECT_TIMEOUT_SECONDS=10
TELEGRAM_READ_TIMEOUT_SECONDS=30
TELEGRAM_MAX_ATTEMPTS=2

# Email alerts (optional)
# Configure with your SMTP provider (e.g., Gmail/SendGrid/Mailgun SMTP).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=1

# Zyte fallback scraping
ZYTE_API_TOKEN=
ZYTE_PROJECT_ID=
ZYTE_SPIDER_NAME=amazon_price
ZYTE_API_HOST=https://app.zyte.com
ZYTE_STORAGE_HOST=https://storage.zyte.com

# Backend behavior
PRICEPULSE_ENABLE_SCHEDULER=1
PRICEPULSE_SCHEDULER_INTERVAL_MINUTES=30
PRICEPULSE_ENABLE_LOCAL_SCRAPY=1
PRICEPULSE_SCRAPY_LOG_LEVEL=ERROR
PRICEPULSE_ENFORCE_TARGET_BELOW_CURRENT=1
PRICEPULSE_MIN_SEARCH_MATCH_RATIO=0.2
PRICEPULSE_MIN_VALID_PRICE=10
PRICEPULSE_LINK_CHECK_LIMIT=9
PRICEPULSE_LINK_CHECK_TIMEOUT_SECONDS=4
PRICEPULSE_SEARCH_PROVIDERS=amazon,reliance_digital,snapdeal
PRICEPULSE_MAX_SEARCH_RESULTS=9
PRICEPULSE_REQUESTS_PER_MINUTE=60
PRICEPULSE_SKIP_URL_PREFIXES=/private/,/forum/admin/,/admin/,/login,/account/,/share/
PRICEPULSE_SKIP_URL_PATTERNS=[?&](utm_|fbclid|gclid)=,/(cart|checkout|wishlist)(/|$)
CORS_ORIGINS=
